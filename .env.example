# Port (Railway injects it automatically, don't touch it there)
PORT=3000

# Folder where the SQLite database is stored.
# On Railway: create a Volume and mount this path so the data survives redeploys.
DATA_DIR=/data

# Key that Happy Robot must send in the x-api-key header
# when calling /api/jobs/:id/evaluation-config and /api/candidates/score
INTERNAL_API_KEY=change-this-to-a-long-random-key

# --- Ashby ---
# Your Ashby API key (Settings > API in your Ashby account)
ASHBY_API_KEY=

# The ID of the custom field in Ashby where the pre-screening score is stored
# (create it in Ashby and copy its id with customField.list, or from the Ashby UI)
ASHBY_SCORE_FIELD_ID=

# Which object type this custom field lives on: "Application" or "Candidate"
ASHBY_SCORE_OBJECT_TYPE=Application

# --- Agent Interview (Phase 2) ---
# Custom field IDs where the interview score and coverage are written in Ashby.
# If ASHBY_INTERVIEW_SCORE_FIELD_ID is empty, the score is still stored locally
# but not synced to Ashby.
ASHBY_INTERVIEW_SCORE_FIELD_ID=
ASHBY_INTERVIEW_COVERAGE_FIELD_ID=
# Object type the interview custom fields live on (usually Application).
ASHBY_INTERVIEW_OBJECT_TYPE=Application

# How /interview/lookup identifies the "Agent Interview" stage. Prefer the exact
# stage ID; otherwise it falls back to matching this stage name.
ASHBY_AGENT_INTERVIEW_STAGE_ID=
ASHBY_AGENT_INTERVIEW_STAGE_NAME=Agent Interview

# Whether the voice agent should record calls (surfaced by /interview/lookup).
INTERVIEW_RECORDING_ENABLED=false
