# Puerto (Railway lo inyecta automáticamente, no lo toques ahí)
PORT=3000

# Carpeta donde se guarda la base de datos SQLite.
# En Railway: crea un Volume y monta esta ruta para que los datos sobrevivan a los redeploys.
DATA_DIR=/data

# Clave que Happy Robot debe enviar en el header x-api-key
# al llamar a /api/jobs/:id/evaluation-config y /api/candidates/score
INTERNAL_API_KEY=cambia-esto-por-una-clave-larga-y-aleatoria

# --- Ashby ---
# Tu API key de Ashby (Settings > API en tu cuenta de Ashby)
ASHBY_API_KEY=

# El ID del custom field en Ashby donde se guarda el score de pre-screening
# (créalo en Ashby y copia su id con customField.list, o desde la UI de Ashby)
ASHBY_SCORE_FIELD_ID=

# Sobre qué tipo de objeto vive ese custom field: "Application" o "Candidate"
ASHBY_SCORE_OBJECT_TYPE=Application
